# Groww App Review Analyst - Environment Variables
# Copy this file to .env and fill in your values.

# Groq Cloud API Key (Phase 2 - LLM Analysis)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# MCP Server URL (Phase 3 - set after deploying to Railway)
# Example: https://your-app.up.railway.app/sse
# Leave blank for local stdio mode
MCP_SERVER_URL=

# Google Auth (Railway deployment only - paste raw JSON contents)
# GOOGLE_TOKEN_JSON={"token": "...", ...}
# GOOGLE_CREDENTIALS_JSON={"installed": {"client_id": "...", ...}}

# Scheduler Config (Phase 6 - GitHub Actions)
# These are required for automated scheduled runs
TARGET_DOC_ID=your_google_doc_id_here
TARGET_EMAIL=your_email@example.com
REVIEW_COUNT=500
